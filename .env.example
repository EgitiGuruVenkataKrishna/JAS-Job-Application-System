# ============================================================
# JAS — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Google Gemini ---
GEMINI_API_KEY=AIza...

# --- Telegram ---
TELEGRAM_BOT_TOKEN=7123456789:AAH...
TELEGRAM_CHAT_ID=123456789

# --- Supabase ---
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# --- Thresholds ---
COSINE_THRESHOLD=0.77
COVER_LETTER_SCORE_THRESHOLD=90

# --- Scheduling (cron-style) ---
INGESTION_INTERVAL_HOURS=4
DIGEST_HOUR=21

# --- Output Paths ---
OUTPUT_DIR=output
